{
  "id": "/",
  "short_name": "BookVerse",
  "name": "BookVerse - Leitor Digital & Audiolivros",
  "description": "Sua biblioteca digital premium offline com assistente de IA Gemini integrado e audiolivros.",
  "lang": "pt-BR",
  "dir": "ltr",
  "scope": "/",
  "start_url": "/",
  "display": "standalone",
  "display_override": ["standalone", "window-controls-overlay", "minimal-ui"],
  "orientation": "portrait-primary",
  "background_color": "#121214",
  "theme_color": "#121214",
  "prefer_related_applications": false,
  "related_applications": [],
  "categories": ["books", "education", "productivity"],
  "icons": [
    {
      "src": "/bookverse_logo_48.png",
      "type": "image/png",
      "sizes": "48x48",
      "purpose": "any"
    },
    {
      "src": "/bookverse_logo_72.png",
      "type": "image/png",
      "sizes": "72x72",
      "purpose": "any"
    },
    {
      "src": "/bookverse_logo_96.png",
      "type": "image/png",
      "sizes": "96x96",
      "purpose": "any"
    },
    {
      "src": "/bookverse_logo_128.png",
      "type": "image/png",
      "sizes": "128x128",
      "purpose": "any"
    },
    {
      "src": "/bookverse_logo_144.png",
      "type": "image/png",
      "sizes": "144x144",
      "purpose": "any"
    },
    {
      "src": "/bookverse_logo_152.png",
      "type": "image/png",
      "sizes": "152x152",
      "purpose": "any"
    },
    {
      "src": "/bookverse_logo_192.png",
      "type": "image/png",
      "sizes": "192x192",
      "purpose": "any"
    },
    {
      "src": "/bookverse_logo_192.png",
      "type": "image/png",
      "sizes": "192x192",
      "purpose": "maskable"
    },
    {
      "src": "/bookverse_logo_384.png",
      "type": "image/png",
      "sizes": "384x384",
      "purpose": "any"
    },
    {
      "src": "/bookverse_logo_512.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "any"
    },
    {
      "src": "/bookverse_logo_512.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshot-desktop.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "BookVerse Biblioteca Premium - Desktop View"
    },
    {
      "src": "/screenshot-mobile.png",
      "sizes": "720x1280",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "BookVerse Biblioteca Premium - Mobile View"
    }
  ],
  "shortcuts": [
    {
      "name": "Ver Biblioteca",
      "url": "/",
      "icons": [{ "src": "/bookverse_logo_192.png", "sizes": "192x192", "type": "image/png" }]
    }
  ],
  "scope_extensions": [
    { "origin": "*.run.app" }
  ],
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "text/plain": [".txt"],
        "application/epub+zip": [".epub"]
      }
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "protocol_handlers": [
    {
      "protocol": "web+bookverse",
      "url": "/?book=%s"
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "note_taking": {
    "new_note_url": "/?action=new-note"
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "iarc_rating_id": ""
}
