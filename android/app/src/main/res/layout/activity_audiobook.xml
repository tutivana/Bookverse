<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black_bg"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <!-- Top nav bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="32dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            style="@style/Widget.Material3.Button.TextButton"
            app:icon="@android:drawable/ic_menu_revert"
            app:iconTint="@color/zinc_100" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tocando Audiobook"
            android:textColor="@color/zinc_400"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Album art illustration placeholder -->
    <androidx.cardview.widget.CardView
        android:layout_width="200dp"
        android:layout_height="200dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/card_bg"
        android:layout_marginBottom="32dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_lock_silent_mode"
            app:tint="@color/gold_amber"
            android:padding="48dp" />
    </androidx.cardview.widget.CardView>

    <!-- Details -->
    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dom Casmurro"
        android:textColor="@color/zinc_100"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/txtAuthor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Machado de Assis"
        android:textColor="@color/zinc_400"
        android:textSize="14sp"
        android:layout_marginBottom="32dp" />

    <!-- Seekbar slider -->
    <SeekBar
        android:id="@+id/seekBarProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp" />

    <!-- Timer readings -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="32dp">

        <TextView
            android:id="@+id/txtCurrentTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="00:00"
            android:textColor="@color/zinc_400"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/txtTotalTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="30:45"
            android:textColor="@color/zinc_400"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Player Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="32dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRewind"
            android:layout_width="56dp"
            android:layout_height="56dp"
            style="@style/Widget.Material3.Button.IconButton"
            app:icon="@android:drawable/ic_media_rew"
            app:iconTint="@color/zinc_100"
            android:layout_marginEnd="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlayPause"
            android:layout_width="72dp"
            android:layout_height="72dp"
            style="@style/Widget.Material3.Button.FilledButton"
            app:icon="@android:drawable/ic_media_play"
            app:iconSize="32dp"
            app:backgroundTint="@color/gold_amber"
            app:iconTint="@color/black_bg" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnForward"
            android:layout_width="56dp"
            android:layout_height="56dp"
            style="@style/Widget.Material3.Button.IconButton"
            app:icon="@android:drawable/ic_media_ff"
            app:iconTint="@color/zinc_100"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <!-- Speed modifier -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSpeed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1.0x"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:textColor="@color/gold_amber"
        app:strokeColor="@color/gold_amber" />

</LinearLayout>
