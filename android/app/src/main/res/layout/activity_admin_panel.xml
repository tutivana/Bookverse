<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black_bg"
    android:padding="16dp">

    <!-- Top navigation back bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            style="@style/Widget.Material3.Button.TextButton"
            app:icon="@android:drawable/ic_menu_revert"
            app:iconTint="@color/zinc_100" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Painel Administrativo"
            android:textColor="@color/zinc_100"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ADMIN"
            android:textColor="@color/orange_admin"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@color/card_bg"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp" />
    </LinearLayout>

    <!-- Administrative Statistics counters -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@color/card_bg"
            android:padding="12dp"
            android:layout_marginEnd="4dp"
            android:gravity="center">

            <TextView
                android:id="@+id/txtStatsBooks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Livros: 4"
                android:textColor="@color/zinc_100"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@color/card_bg"
            android:padding="12dp"
            android:layout_marginStart="4dp"
            android:gravity="center">

            <TextView
                android:id="@+id/txtStatsUsers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Usuários: 4"
                android:textColor="@color/orange_admin"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Add Book Form Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Adicionar Novo Livro ao Catálogo"
        android:textColor="@color/zinc_100"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/card_bg"
        android:padding="12dp"
        android:layout_marginBottom="24dp">

        <EditText
            android:id="@+id/editNewBookTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Título da Obra"
            android:textColor="@color/zinc_100"
            android:textColorHint="@color/zinc_400"
            android:layout_marginBottom="8dp"
            android:padding="12dp"
            android:background="@color/black_bg" />

        <EditText
            android:id="@+id/editNewBookAuthor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nome do Autor"
            android:textColor="@color/zinc_100"
            android:textColorHint="@color/zinc_400"
            android:layout_marginBottom="12dp"
            android:padding="12dp"
            android:background="@color/black_bg" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddBook"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="INSERIR NO ACERVO"
            android:textColor="@color/black_bg"
            app:backgroundTint="@color/orange_admin"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Users list view -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lista de Usuários Cadastrados"
        android:textColor="@color/zinc_100"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <ListView
        android:id="@+id/listUsersView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/card_bg"
        android:divider="@color/zinc_800"
        android:dividerHeight="1dp" />

</LinearLayout>
