<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black_bg"
    android:padding="20dp">

    <!-- Header back bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            style="@style/Widget.Material3.Button.TextButton"
            app:icon="@android:drawable/ic_menu_revert"
            app:iconTint="@color/zinc_100" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Suporte e Feedback"
            android:textColor="@color/zinc_100"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Como podemos te ajudar hoje?"
        android:textColor="@color/gold_amber"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Escreva abaixo suas dúvidas, sugestões de melhoria ou reporte algum erro técnico. Sua mensagem será enviada diretamente ao nosso painel administrativo de notificações."
        android:textColor="@color/zinc_400"
        android:textSize="12sp"
        android:layout_marginBottom="20dp" />

    <EditText
        android:id="@+id/editSupportMessage"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:hint="Escreva aqui sua mensagem..."
        android:gravity="top"
        android:padding="16dp"
        android:textColor="@color/zinc_100"
        android:textColorHint="@color/zinc_400"
        android:background="@color/card_bg"
        android:layout_marginBottom="24dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSendSupport"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ENVIAR FEEDBACK AOS ADMINISTRADORES"
        android:textColor="@color/black_bg"
        app:backgroundTint="@color/gold_amber"
        android:textStyle="bold"
        android:padding="16dp" />

</LinearLayout>
