<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black_bg"
    android:gravity="center_horizontal"
    android:padding="24dp">

    <!-- Top Accent Bar -->
    <View
        android:id="@+id/topAccentBar"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:background="@color/gold_amber" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="32dp">

            <!-- Logo representation -->
            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@android:drawable/ic_menu_book"
                app:tint="@color/gold_amber"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/portalTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BookVerse"
                android:textColor="@color/zinc_100"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/portalSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sua biblioteca inteligente de audiobooks &amp; PDFs"
                android:textColor="@color/zinc_400"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"
                android:gravity="center" />

            <!-- Segmented Control tabs: Public vs Admin -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/card_bg"
                android:padding="4dp"
                android:layout_marginBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTabPublic"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Público"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:textColor="@color/zinc_100"
                    app:strokeColor="@color/gold_amber" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTabAdmin"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Admin"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:textColor="@color/zinc_400"
                    app:strokeColor="@color/orange_admin" />
            </LinearLayout>

            <!-- Role Options selector -->
            <LinearLayout
                android:id="@+id/roleSelectionContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selecione o seu perfil de acesso"
                    android:textColor="@color/zinc_400"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_gravity="center"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRoleOption1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Leitor"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:textColor="@color/gold_amber"
                        android:layout_marginEnd="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRoleOption2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Moderador"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:textColor="@color/zinc_400"
                        android:layout_marginStart="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Inputs -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:textColorHint="@color/zinc_400">

                <EditText
                    android:id="@+id/emailInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="E-mail"
                    android:background="@color/card_bg"
                    android:textColor="@color/zinc_100"
                    android:inputType="textEmailAddress"
                    android:padding="16dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:textColorHint="@color/zinc_400">

                <EditText
                    android:id="@+id/passwordInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Senha"
                    android:background="@color/card_bg"
                    android:textColor="@color/zinc_100"
                    android:inputType="textPassword"
                    android:padding="16dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ENTRAR NO SISTEMA"
                android:textColor="@color/black_bg"
                app:backgroundTint="@color/gold_amber"
                android:padding="16dp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
