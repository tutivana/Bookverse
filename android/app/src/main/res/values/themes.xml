<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.BookVerse" parent="Theme.Material3.DayNight">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/gold_amber</item>
        <item name="colorOnPrimary">@color/black_bg</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/black_bg</item>
        <item name="android:windowBackground">@color/black_bg</item>
    </style>

    <style name="Theme.BookVerse.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
</resources>
